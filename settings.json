{
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf --no-preserve-root /)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(prisma reset *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "mgrep@Mixedbread-Grep": true,
    "claude-mem@thedotmack": true
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/src/claude-config/scripts/format-on-save.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/src/claude-config/scripts/protect-env.sh"
          }
        ]
      },
      {
        "_tag": "ccstatusline-managed",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ],
        "matcher": "Skill"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/src/claude-config/scripts/bell.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/src/claude-config/scripts/bell.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  }
}